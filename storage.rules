rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Fotos das participacoes: leitura publica, upload/troca so pelo admin.
    match /fotos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid in [
        "Wn5M3EGo8thlchIfqFgxwhfgvo22",
        "lvXffI2cgXSMiLapxOwbHAw4DVK2",
        "cy29ZgCjcOTVaPETcZ47gCsbGUQ2"
      ];
    }
  }
}
